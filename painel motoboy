<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Painel Motoboy</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/zone.js/0.14.4/zone.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/rxjs/7.8.1/rxjs.umd.min.js"></script>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { background: #1a1a1a; font-family: 'Segoe UI', Arial, sans-serif; color: #fff; min-height: 100vh; }

  /* TELA DE LOGIN */
  .login-screen {
    display: flex; align-items: center; justify-content: center;
    min-height: 100vh; background: #111;
  }
  .login-card {
    background: #1e1e1e; border-radius: 16px; padding: 40px 32px;
    width: 100%; max-width: 420px; text-align: center;
  }
  .login-icon {
    width: 72px; height: 72px; background: #2a2a2a; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 20px; font-size: 32px;
  }
  .login-title { font-size: 22px; font-weight: 600; margin-bottom: 6px; }
  .login-subtitle { font-size: 13px; color: #888; margin-bottom: 28px; }
  .profile-option {
    display: flex; align-items: center; justify-content: space-between;
    background: #2a2a2a; border-radius: 10px; padding: 14px 16px;
    margin-bottom: 12px; cursor: pointer; transition: background 0.2s;
    border: 1px solid #333;
  }
  .profile-option:hover { background: #333; }
  .profile-left { display: flex; align-items: center; gap: 12px; }
  .profile-avatar {
    width: 44px; height: 44px; border-radius: 50%; object-fit: cover;
    background: #555; display: flex; align-items: center; justify-content: center;
    font-size: 18px; font-weight: 700; color: #fff;
  }
  .profile-name { font-size: 15px; font-weight: 500; text-align: left; }
  .profile-meta { font-size: 12px; color: #f5b642; margin-top: 2px; }
  .profile-arrow { color: #666; font-size: 18px; }
  .btn-voltar {
    width: 100%; margin-top: 8px; padding: 13px; border: 1px solid #444;
    background: transparent; color: #ccc; border-radius: 8px; cursor: pointer;
    font-size: 14px; transition: background 0.2s;
  }
  .btn-voltar:hover { background: #2a2a2a; }

  /* PAINEL PRINCIPAL */
  .painel { display: none; flex-direction: column; min-height: 100vh; }
  .painel.ativo { display: flex; }

  /* HEADER */
  .header {
    background: #1e1e1e; padding: 12px 16px;
    display: flex; align-items: center; justify-content: space-between;
    border-bottom: 1px solid #2a2a2a;
  }
  .header-left { display: flex; align-items: center; gap: 10px; }
  .header-avatar {
    width: 36px; height: 36px; border-radius: 50%; background: #555;
    display: flex; align-items: center; justify-content: center;
    font-size: 14px; font-weight: 700;
  }
  .header-info { line-height: 1.3; }
  .header-name { font-size: 14px; font-weight: 600; }
  .header-rating { font-size: 11px; color: #f5b642; }
  .header-right { display: flex; align-items: center; gap: 10px; }
  .btn-sair {
    background: transparent; border: 1px solid #444; color: #aaa;
    padding: 6px 12px; border-radius: 6px; cursor: pointer; font-size: 12px;
  }
  .toggle-wrap { display: flex; align-items: center; gap: 8px; font-size: 12px; }
  .status-dot { width: 8px; height: 8px; border-radius: 50%; }
  .status-dot.online { background: #4caf50; }
  .status-dot.offline { background: #f44336; }
  .toggle {
    position: relative; width: 44px; height: 22px; cursor: pointer;
  }
  .toggle input { opacity: 0; width: 0; height: 0; }
  .toggle-slider {
    position: absolute; inset: 0; background: #444; border-radius: 22px;
    transition: 0.3s;
  }
  .toggle-slider:before {
    content: ''; position: absolute; width: 16px; height: 16px;
    background: #fff; border-radius: 50%; left: 3px; top: 3px; transition: 0.3s;
  }
  .toggle input:checked + .toggle-slider { background: #4caf50; }
  .toggle input:checked + .toggle-slider:before { transform: translateX(22px); }

  /* STATS */
  .stats-bar {
    display: grid; grid-template-columns: 1fr 1fr 1fr;
    background: #1e1e1e; border-bottom: 1px solid #2a2a2a;
  }
  .stat-item {
    padding: 14px 12px; text-align: center; border-right: 1px solid #2a2a2a;
  }
  .stat-item:last-child { border-right: none; }
  .stat-value { font-size: 17px; font-weight: 700; color: #f5b642; }
  .stat-label { font-size: 11px; color: #888; margin-top: 2px; }
  .stat-gps { font-size: 12px; color: #4caf50; cursor: pointer; }
  .stat-gps.off { color: #888; }

  /* TABS */
  .tabs {
    display: flex; background: #1a1a1a; padding: 10px 12px; gap: 6px;
    overflow-x: auto;
  }
  .tab {
    padding: 8px 14px; border-radius: 20px; font-size: 12px; cursor: pointer;
    white-space: nowrap; border: 1px solid #333; background: transparent;
    color: #888; transition: all 0.2s;
  }
  .tab.ativo { background: #f5b642; color: #111; border-color: #f5b642; font-weight: 600; }

  /* OFFLINE BANNER */
  .offline-banner {
    background: #2a1f00; border: 1px solid #5a3d00; margin: 12px;
    border-radius: 10px; padding: 12px 14px; display: flex; align-items: flex-start; gap: 10px;
  }
  .offline-banner .icon { font-size: 16px; margin-top: 1px; }
  .offline-title { font-size: 13px; font-weight: 600; color: #f5b642; }
  .offline-sub { font-size: 12px; color: #a07830; margin-top: 2px; }

  /* SEÇÃO DE PEDIDOS */
  .secao { margin: 0 12px 12px; }
  .secao-header {
    display: flex; align-items: center; gap: 8px; margin-bottom: 10px;
    font-size: 11px; font-weight: 700; letter-spacing: 1px; color: #f44336;
    text-transform: uppercase;
  }
  .secao-header .fire { font-size: 14px; }

  /* CARD PEDIDO */
  .card-pedido {
    background: #1e1e1e; border-radius: 12px; padding: 14px;
    margin-bottom: 10px; border: 1px solid #2a2a2a;
  }
  .card-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 10px; }
  .pedido-nome { font-size: 14px; font-weight: 600; }
  .pedido-num { font-size: 11px; color: #666; margin-top: 2px; }
  .pedido-preco {
    background: #f5b642; color: #111; font-weight: 700; font-size: 13px;
    padding: 5px 10px; border-radius: 8px; white-space: nowrap;
  }
  .pedido-dist { font-size: 11px; color: #888; text-align: right; margin-top: 3px; }
  .rota-item { display: flex; align-items: flex-start; gap: 8px; margin-bottom: 6px; }
  .rota-dot {
    width: 10px; height: 10px; border-radius: 50%; margin-top: 3px; flex-shrink: 0;
  }
  .rota-dot.origem { background: #f5b642; }
  .rota-dot.destino { background: #4caf50; }
  .rota-label { font-size: 10px; color: #888; }
  .rota-end { font-size: 12px; color: #ddd; }
  .card-btns { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-top: 12px; }
  .card-btns-3 { display: grid; grid-template-columns: 1fr auto 1fr; gap: 6px; margin-top: 8px; }
  .btn-map, .btn-waze, .btn-rota, .btn-aceitar, .btn-recusar {
    padding: 10px; border-radius: 8px; font-size: 12px; font-weight: 600;
    cursor: pointer; border: none; transition: all 0.2s; text-align: center;
  }
  .btn-map { background: #2a2a2a; color: #ddd; border: 1px solid #444; }
  .btn-map:hover { background: #333; }
  .btn-waze { background: #2a2a2a; color: #59d0ff; border: 1px solid #444; }
  .btn-waze:hover { background: #333; }
  .btn-rota { background: #2a2a2a; color: #ddd; border: 1px solid #444; font-size: 11px; }
  .btn-aceitar { background: #f5b642; color: #111; }
  .btn-aceitar:hover { background: #e6a730; }
  .btn-recusar { background: #2a2a2a; color: #f44336; border: 1px solid #444; padding: 10px 14px; }

  /* LOCALIZAÇÃO */
  .loc-card {
    background: #1e1e1e; border-radius: 12px; padding: 14px;
    margin: 12px; border: 1px solid #2a2a2a;
  }
  .loc-title { font-size: 13px; font-weight: 600; margin-bottom: 10px; color: #f5b642; }
  .loc-info { font-size: 12px; color: #aaa; line-height: 1.8; }
  .loc-coords { font-family: monospace; font-size: 12px; color: #4caf50; }
  .loc-map {
    width: 100%; height: 200px; background: #111; border-radius: 8px;
    margin-top: 10px; display: flex; align-items: center; justify-content: center;
    position: relative; overflow: hidden; border: 1px solid #333;
  }
  .loc-map-grid {
    position: absolute; inset: 0;
    background-image: linear-gradient(#2a2a2a 1px, transparent 1px),
      linear-gradient(90deg, #2a2a2a 1px, transparent 1px);
    background-size: 30px 30px;
  }
  .loc-pin {
    position: absolute; top: 50%; left: 50%; transform: translate(-50%, -100%);
    font-size: 28px; z-index: 2; animation: pulse 1.5s ease-in-out infinite;
  }
  .loc-circle {
    position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
    width: 60px; height: 60px; border-radius: 50%;
    background: rgba(245,182,66,0.15); border: 2px solid rgba(245,182,66,0.4);
    animation: ripple 2s ease-out infinite;
  }
  @keyframes pulse { 0%,100%{transform:translate(-50%,-100%) scale(1)} 50%{transform:translate(-50%,-110%) scale(1.1)} }
  @keyframes ripple { 0%{transform:translate(-50%,-50%) scale(0.5);opacity:1} 100%{transform:translate(-50%,-50%) scale(2.5);opacity:0} }
  .loc-status { text-align: center; font-size: 12px; color: #888; margin-top: 8px; }

  /* EMPTY STATE */
  .empty { text-align: center; padding: 40px 20px; color: #555; }
  .empty-icon { font-size: 40px; margin-bottom: 12px; }
  .empty-text { font-size: 14px; }

  /* PEDIDO ATIVO */
  .ativo-badge {
    display: inline-block; background: #1a3a1a; color: #4caf50;
    font-size: 10px; font-weight: 700; padding: 3px 8px; border-radius: 20px;
    border: 1px solid #2d5a2d; margin-bottom: 8px;
  }
  .btn-entregar { 
    width: 100%; padding: 14px; background: #4caf50; color: #fff;
    border: none; border-radius: 10px; font-size: 14px; font-weight: 700;
    cursor: pointer; margin-top: 10px;
  }
  .btn-entregar:hover { background: #43a047; }

  /* HISTORICO */
  .hist-item {
    background: #1e1e1e; border-radius: 10px; padding: 12px 14px;
    margin-bottom: 8px; border: 1px solid #2a2a2a;
    display: flex; justify-content: space-between; align-items: center;
  }
  .hist-nome { font-size: 13px; font-weight: 500; }
  .hist-data { font-size: 11px; color: #666; margin-top: 2px; }
  .hist-preco { color: #4caf50; font-weight: 700; font-size: 14px; }

  /* NOTIF TOAST */
  .toast {
    position: fixed; bottom: 20px; left: 50%; transform: translateX(-50%);
    background: #333; color: #fff; padding: 12px 20px; border-radius: 10px;
    font-size: 13px; z-index: 999; opacity: 0; transition: opacity 0.3s;
    pointer-events: none; border: 1px solid #444;
  }
  .toast.show { opacity: 1; }
</style>
</head>
