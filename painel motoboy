          <div>
            <div class="hist-nome">Patricia Mendes</div>
            <div class="hist-data">Ontem, 19:44 · Pedido #ve-003</div>
          </div>
          <div class="hist-preco">R$ 11,00</div>
        </div>
        <div class="hist-item">
          <div>
            <div class="hist-nome">Lucas Teixeira</div>
            <div class="hist-data">Ontem, 18:20 · Pedido #ve-002</div>
          </div>
          <div class="hist-preco">R$ 8,50</div>
        </div>
      </div>
    </div>

  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<script>
// ===== ESTADO =====
let online = false;
let entregasFeitas = 0;
let ganhos = 0;
let pedidoAtivo = null;
let gpsWatchId = null;
let posAtual = null;

// ===== LOGIN =====
function entrar(nome, rating, entregas) {
  const primeiros = nome.split(' ').map(p => p[0]).join('').slice(0,2);
  document.getElementById('telaLogin').style.display = 'none';
  document.getElementById('painelPrincipal').classList.add('ativo');
  document.getElementById('headerNome').textContent = 'Olá, ' + nome.split(' ')[0] + '!';
  document.getElementById('headerRating').textContent = '⭐ ' + rating + ' · ' + entregas + ' entregas';
  document.getElementById('headerAvatar').textContent = primeiros;
  document.getElementById('statEntregas').textContent = entregas;
  showToast('Bem-vindo(a), ' + nome.split(' ')[0] + '! 👋');
  updateStatusUI();
}

function sair() {
  document.getElementById('telaLogin').style.display = 'flex';
  document.getElementById('painelPrincipal').classList.remove('ativo');
  online = false;
  if (gpsWatchId) navigator.geolocation.clearWatch(gpsWatchId);
  document.getElementById('toggleOnline').checked = false;
  updateStatusUI();
}

// ===== STATUS =====
function toggleStatus() {
  online = document.getElementById('toggleOnline').checked;
  updateStatusUI();
  showToast(online ? '🟢 Você está online!' : '🔴 Você está offline');
}

function updateStatusUI() {
  const dot = document.getElementById('statusDot');
  const banner = document.getElementById('offlineBanner');
  dot.className = 'status-dot ' + (online ? 'online' : 'offline');
  if (banner) banner.style.display = online ? 'none' : 'flex';
}

// ===== TABS =====
function mudarTab(tab, el) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('ativo'));
  el.classList.add('ativo');
  ['disponiveis','rastreador','ativas','historico'].forEach(t => {
    const el2 = document.getElementById('tab-' + t);
    if (el2) el2.style.display = t === tab ? 'block' : 'none';
  });
  if (tab === 'rastreador') ativarGPS();
}

// ===== GPS =====
function ativarGPS() {
  if (!navigator.geolocation) {
    document.getElementById('gpsStatus').textContent = 'GPS não suportado';
    document.getElementById('gpsStatus').style.color = '#f44336';
    return;
  }
  document.getElementById('gpsStatus').textContent = 'Obtendo localização...';
  document.getElementById('gpsStatus').style.color = '#f5b642';
  document.getElementById('locStatus').textContent = 'Localizando...';

  if (gpsWatchId) navigator.geolocation.clearWatch(gpsWatchId);

  gpsWatchId = navigator.geolocation.watchPosition(
    function(pos) {
      posAtual = pos;
      const lat = pos.coords.latitude.toFixed(6);
      const lng = pos.coords.longitude.toFixed(6);
      const acc = Math.round(pos.coords.accuracy);
      const agora = new Date().toLocaleTimeString('pt-BR');

      document.getElementById('gpsStatus').textContent = '✅ GPS Ativo';
      document.getElementById('gpsStatus').style.color = '#4caf50';
      document.getElementById('gpsCoords').textContent = lat + ', ' + lng;
      document.getElementById('gpsPrecisao').textContent = '±' + acc + ' metros';
      document.getElementById('gpsHora').textContent = agora;
      document.getElementById('locStatus').textContent = '📍 Lat: ' + lat + ' · Lng: ' + lng;

      const statGps = document.getElementById('statGps');
      statGps.textContent = '📍 GPS Ativo';
      statGps.className = 'stat-gps';

      animarPin();
    },
    function(err) {
      document.getElementById('gpsStatus').textContent = 'Erro: ' + err.message;
      document.getElementById('gpsStatus').style.color = '#f44336';
      document.getElementById('locStatus').textContent = 'Não foi possível obter localização';
      showToast('❌ Erro GPS: ' + err.message);
    },
    { enableHighAccuracy: true, timeout: 15000, maximumAge: 5000 }
  );
}

function animarPin() {
  const pin = document.getElementById('locPin');
  if (!pin) return;
  pin.style.transform = 'translate(-50%, -120%)';
  setTimeout(() => pin.style.transform = 'translate(-50%, -100%)', 300);
}

// ===== PEDIDOS =====
function aceitarPedido(cardId, nome, preco) {
  if (!online) {
    showToast('⚠️ Fique online para aceitar pedidos!');
    return;
  }
  document.getElementById(cardId).remove();
  pedidoAtivo = { nome, preco, card: cardId };

  // Atualiza aba ativas
  const ativasContent = document.getElementById('ativasContent');
  ativasContent.innerHTML = `
    <div style="padding:12px">
      <div class="card-pedido">
        <div class="ativo-badge">EM ANDAMENTO</div>
        <div class="card-top">
          <div>
            <div class="pedido-nome">${nome}</div>
            <div class="pedido-num">Em entrega</div>
          </div>
          <div class="pedido-preco">${preco}</div>
        </div>
        <div class="rota-item">
          <div class="rota-dot destino"></div>
          <div>
            <div class="rota-label">Indo para</div>
            <div class="rota-end">Endereço do cliente</div>
          </div>
        </div>
        <button class="btn-entregar" onclick="finalizarEntrega('${preco}')">✅ Confirmar Entrega</button>
      </div>
    </div>`;

  // Atualiza contador na tab
  document.querySelectorAll('.tab')[2].textContent = '🛵 Ativas (1)';
  showToast('✅ Pedido aceito! Boa entrega 🛵');
}

function recusarPedido(cardId) {
  const card = document.getElementById(cardId);
  card.style.opacity = '0'; card.style.transform = 'translateX(-20px)';
  card.style.transition = 'all 0.3s';
  setTimeout(() => card.remove(), 300);
  showToast('Pedido recusado');
}

function finalizarEntrega(preco) {
  const val = parseFloat(preco.replace('R$ ','').replace(',','.'));
  ganhos += val;
  entregasFeitas++;
  document.getElementById('statGanhos').textContent = 'R$ ' + ganhos.toFixed(2).replace('.',',');
  document.getElementById('statEntregas').textContent = entregasFeitas;

  document.getElementById('ativasContent').innerHTML = `
    <div class="empty">
      <div class="empty-icon">🛵</div>
      <div class="empty-text">Nenhuma entrega ativa no momento</div>
    </div>`;
  document.querySelectorAll('.tab')[2].textContent = '🛵 Ativas (0)';
  showToast('🎉 Entrega concluída! + ' + preco);
  pedidoAtivo = null;
}

// ===== MAPAS =====
function abrirMaps(lat, lng) {
  window.open('https://www.google.com/maps/search/?api=1&query=' + lat + ',' + lng, '_blank');
}
function abrirWaze(lat, lng) {
  window.open('https://waze.com/ul?ll=' + lat + ',' + lng + '&navigate=yes', '_blank');
}
function verRota(pedidoId) {
  showToast('Abrindo rota para o pedido #' + pedidoId + '...');
  if (posAtual) {
    const lat = posAtual.coords.latitude;
    const lng = posAtual.coords.longitude;
    window.open('https://www.google.com/maps/dir/' + lat + ',' + lng + '/-23.664,-46.779', '_blank');
  } else {
    showToast('⚠️ Ative o GPS para ver a rota a partir de você');
  }
}

// ===== TOAST =====
function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2800);
}

// Init
updateStatusUI();
</script>
</body>
</html>